<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:thickness="4dp" android:useLevel="false">
            <solid android:color="#A9A9A9" /> </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="-90" android:toDegrees="-90">
            <shape android:shape="ring" android:thickness="4dp" android:useLevel="true">
                <solid android:color="#FFFFFF" /> </shape>
        </rotate>
    </item>
</layer-list>