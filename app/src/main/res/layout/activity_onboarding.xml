<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvWelcomeHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Habit Tracker"
            android:textColor="#4A148C"
            android:textSize="28dp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/tvTutorialText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Track your habits, build your streaks, and grow every day. What should we call you?"
            android:textColor="#000000"
            android:textSize="16dp"
            android:textAlignment="center" />

        <EditText
            android:id="@+id/etUserName"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Enter your name..."
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="18dp" />

        <Button
            android:id="@+id/btnStartBlooming"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Let's go! :)))"
            android:textSize="18dp"
            android:backgroundTint="#CE93D8"
            android:textColor="#FFFFFF"
            app:cornerRadius="30dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>